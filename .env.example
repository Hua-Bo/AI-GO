# ⚠️ 请复制本文件为 .env.local 再填写（仅本地开发可选）
# GitHub Pages 线上部署不读取此文件，用户需在页面 AI 配置弹窗自填 Key

# ── 旅游攻略 AI（GitHub Pages 静态部署版）──
# 线上：用户在页面填写 Key，保存在浏览器 localStorage
# 本地开发：可在下方填写 Key 方便调试（不会提交到 Git）

VITE_APP_TITLE=AI旅游攻略推荐
VITE_AI_PROVIDER=longcat
VITE_AI_BASE_URL=https://api.longcat.chat/openai/v1
VITE_AI_MODEL=LongCat-2.0
# 留空：强制用户在页面填写自己的 Key
VITE_AI_API_KEY=

# 可选：高德 Web 服务 Key（用于驾车路径高速费，浏览器直连可能受 CORS 限制；无 Key 时用里程粗估）
# VITE_AMAP_KEY=

# ── 其他 AI 智能体模块（可选）──
VITE_AI_DEFAULT_PROVIDER=mock
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_QWEN_API_KEY=
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_QWEN_MODEL=qwen-plus
VITE_ZHIPU_API_KEY=
VITE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_ZHIPU_MODEL=glm-4-flash
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
VITE_DEEPSEEK_MODEL=deepseek-chat

# ── AI 农业种植助手 ──
# true=演示 Mock；false=调用真实后端 VITE_API_BASE_URL
VITE_USE_MOCK=true
VITE_API_BASE_URL=/api


# ── 云服务器部署专用（GitHub Pages 不使用，见 DEPLOY.md）──
# PORT=3000
# AI_API_KEY=请填写服务端_Key
